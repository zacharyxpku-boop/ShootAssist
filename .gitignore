# Xcode
# 整个 .xcodeproj 由 project.yml + xcodegen 在 CI 构建时重新生成
# 本地 commit 进来的 pbxproj 容易累积死引用，干脆忽略
ShootAssist.xcodeproj/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcworkspace/contents.xcworkspacedata
DerivedData/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# Build
build/
*.o
*.d

# Swift Package Manager
.build/
*.resolved

# CocoaPods
Pods/

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# 敏感信息
*.env
Config/Secrets.swift
*.txt
export_*.js
inspect*.js

# ML 训练数据（视频太大，不入库）
ml/data/raw_unlabeled/
ml/data/raw_videos/
ml/data/*.png
ml/data/*.json
ml/data/keypoints/
ml/data/.auto_label_progress.json

# ML 中间产物（手势识别已从 App 删除，这些训练产物不进仓库）
ml/__pycache__/
ml/data/
ml/models/*.h5
ml/models/*.pt
ml/models/*.pkl
ml/models/*.onnx
ml/models/*.onnx.data
ml/models/*.tflite
ml/models/*.task
ml/models/*_label_map.json
ml/models/gesture_export/
ml/models/gesture_saved_model/
ml/models/gesture_saved/
ml/*.task

# product docs
product_doc/
